#!/usr/bin/env bash
# Re-capture current counts as the new baseline. Run only after a deliberate
# improvement (or initial bootstrap). Commits the new quality_thresholds.json.
#
# See .claude/skills/apply-quality-gates/SKILL.md

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

OUT="tmp/quality"
mkdir -p "$OUT"

swiftlint lint --reporter json > "$OUT/swiftlint.json" 2>/dev/null || true
periphery scan --format json   > "$OUT/periphery.json" 2>/dev/null || true

swift test --enable-code-coverage > "$OUT/swift-test.log" 2>&1 || true

ARCH="$(uname -m)"
PROFDATA=".build/${ARCH}-apple-macosx/debug/codecov/default.profdata"
TESTBIN=".build/${ARCH}-apple-macosx/debug/RetypoAirPackageTests.xctest/Contents/MacOS/RetypoAirPackageTests"
if [ -f "$PROFDATA" ] && [ -f "$TESTBIN" ]; then
    xcrun llvm-cov report "$TESTBIN" \
        -instr-profile="$PROFDATA" \
        -ignore-filename-regex='(Tests|\.build)' \
        > "$OUT/coverage.txt" 2>/dev/null || true
fi

python3 - "$OUT/swiftlint.json" "$OUT/periphery.json" "$OUT/coverage.txt" <<'PY'
import json, sys, datetime, os, re

sl = json.load(open(sys.argv[1]))
ph = json.load(open(sys.argv[2]))

cov_path = sys.argv[3]
line_pct = 0.0
if os.path.exists(cov_path):
    text = open(cov_path).read()
    total = next((l for l in text.splitlines() if l.strip().startswith("TOTAL")), "")
    nums = re.findall(r"([\d.]+)%", total)
    line_pct = float(nums[2]) if len(nums) >= 3 else 0.0

from collections import Counter
rules = Counter(v["rule_id"] for v in sl)

baseline = {
    "_comment": "Ratcheted baseline — see .claude/skills/apply-quality-gates/SKILL.md. Lower numbers via `bin/quality-bump`. Any PR that grows a count fails `bin/quality`.",
    "_captured_at": datetime.date.today().isoformat(),
    "swiftlint": {
        "cyclomatic_complexity":    rules.get("cyclomatic_complexity", 0),
        "function_body_length":     rules.get("function_body_length", 0),
        "type_body_length":         rules.get("type_body_length", 0),
        "file_length":              rules.get("file_length", 0),
        "function_parameter_count": rules.get("function_parameter_count", 0),
        "force_unwrapping":         rules.get("force_unwrapping", 0),
        "force_cast":               rules.get("force_cast", 0),
        "force_try":                rules.get("force_try", 0),
        "total_warnings":           len(sl),
    },
    "periphery": {
        "unused_declarations": len(ph),
    },
    "coverage": {
        "line_coverage_percent_min": round(line_pct, 2),
    },
    "_skipped": {
        "branch_coverage": "Apple platforms expose only line coverage natively",
        "mutation_kill_ratio": "Muter pending — defer until coverage reaches a meaningful floor",
        "dependency_structure": "single SPM target — architecture-theatre at this size",
    },
}

with open("quality_thresholds.json", "w") as f:
    json.dump(baseline, f, indent=2)
    f.write("\n")

print("quality_thresholds.json updated:")
for k, v in baseline["swiftlint"].items():
    print(f"  swiftlint.{k:<28} {v}")
print(f"  periphery.unused_declarations  {baseline['periphery']['unused_declarations']}")
print(f"  coverage.line_coverage_percent_min  {baseline['coverage']['line_coverage_percent_min']}")
PY
