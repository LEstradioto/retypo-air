# Retypo Air API keys
# Copy this file to .env and fill the providers you want to use.

# Default/recommended first provider
GROQ_API_KEY=

# Optional providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional notes:
# - The app loads .env from the directory where you run `swift run`.
# - It also tries ~/.retypo-air/.env.
# - Existing shell environment variables win over values in .env.
